# Grant Dashboard — Ortam Degiskenleri
# cp .env.example .env  →  sonra degerleri doldur

# PostgreSQL (varsayilan SQLite, bu satiri atlayabilirsin):
# DATABASE_URL=postgresql://kullanici:sifre@localhost:5432/grant_dashboard

# E-posta bildirimi (false birakirsan hicbir sey gonderilmez):
NOTIFY_EMAIL_ENABLED=false
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=kullanici@gmail.com
NOTIFY_SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
NOTIFY_FROM=kullanici@gmail.com
NOTIFY_TO=hedef@ornek.com

LOG_LEVEL=INFO
